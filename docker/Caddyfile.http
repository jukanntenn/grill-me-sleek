# grilling-sleek Caddy configuration (HTTP mode for self-hosting)
# Serves static files + reverse proxies to Rust backend
#
# This is the HTTP-only version for self-hosting without TLS.
# For production with TLS, use the main Caddyfile.

{
    auto_https off
}

:8080 {
    # Security headers
    header {
        Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; connect-src 'self'"
        X-Content-Type-Options "nosniff"
    }

    # Compression (exclude SSE path to preserve real-time flush)
    @compressable {
        not path /v1/sessions/*/events
    }
    encode @compressable zstd gzip

    # Static files (served by Caddy, not Rust)
    root * /app/web/dist
    file_server

    # Cache-Control for Entry HTML (5min)
    @html path /
    header @html Cache-Control "public, max-age=300"

    # Cache-Control for assets (immutable, 1 year)
    @assets path /assets/*
    header @assets Cache-Control "public, max-age=31536000, immutable"

    # Reverse proxy to Rust backend
    reverse_proxy /v1/* 127.0.0.1:8000 {
        transport http {
            versions h2c
        }
        health_uri      /v1/healthz
        health_interval 10s
        health_timeout  2s
        flush_interval  -1
    }

    # API responses: no-store
    @api path /v1/*
    header @api Cache-Control "no-store"
}
