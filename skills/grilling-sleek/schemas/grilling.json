{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "Grilling",
  "type": "object",
  "properties": {
    "name": { "type": "string", "description": "会话/问卷名称" },
    "description": { "type": "string", "description": "会话/问卷描述" },
    "additional_notes": {
      "type": "object",
      "description": "全局补充说明框配置",
      "properties": {
        "label": { "type": "string", "description": "框标签文案，缺省走 i18n 默认" },
        "placeholder": { "type": "string", "description": "占位提示，缺省走 i18n 默认" },
        "max_length": { "type": "integer", "description": "最大字符数，不设则不限" },
        "required": { "type": "boolean", "default": false, "description": "true=必填" }
      }
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "snake_case 稳定标识，回答映射 key"
          },
          "header": { "type": "string", "description": "UI 标签" },
          "text": { "type": "string", "description": "完整问题描述" },
          "type": { "type": "string", "enum": ["single", "multi", "text"] },
          "options": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "properties": {
                "label": { "type": "string" },
                "description": { "type": "string" }
              },
              "required": ["label"]
            },
            "description": "single/multi 必需"
          },
          "recommended": {
            "type": "integer",
            "description": "推荐选项的 index"
          },
          "variant": {
            "type": "string",
            "enum": ["default", "yesno", "rating"],
            "default": "default"
          },
          "rating_max": {
            "type": "integer",
            "default": 5,
            "minimum": 2,
            "description": "variant=rating 时的上限"
          },
          "placeholder": {
            "type": "string",
            "description": "text 类型的占位文本"
          },
          "max_length": {
            "type": "integer",
            "description": "text 类型的最大长度"
          },
          "required": {
            "type": "boolean",
            "default": true,
            "description": "false=可不选/可不填"
          },
          "allow_custom_text": {
            "type": "boolean",
            "default": true,
            "description": "显示补充说明框"
          },
          "explanation": {
            "type": "string",
            "description": "推荐理由，显示在 recommended 旁"
          }
        },
        "required": ["id", "header", "text", "type"],
        "allOf": [
          {
            "if": {
              "properties": {
                "type": { "const": "single" },
                "variant": { "not": { "enum": ["yesno", "rating"] } }
              },
              "required": ["type"]
            },
            "then": { "required": ["options"] }
          },
          {
            "if": { "properties": { "type": { "const": "multi" } } },
            "then": { "required": ["options"] }
          }
        ]
      }
    }
  },
  "required": ["name", "questions"]
}
