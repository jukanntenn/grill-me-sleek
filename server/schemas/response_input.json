{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ResponseInput",
  "type": "object",
  "properties": {
    "answers": {
      "type": "object",
      "description": "key 为 question id；value 为该题作答",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "selected": {
            "description": "single/text 题型为 string；multi 题型为 string[]",
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } }
            ]
          },
          "custom_text": { "type": "string" }
        },
        "required": ["selected"]
      }
    },
    "additional_notes": { "type": "string", "description": "全局补充说明" }
  },
  "required": ["answers"]
}
