    "directory": "cli"
  },
  "keywords": [
    "grill-me-sleek",
    "cli",
    "ai",
    "planning",
    "stress-test"
  ],
  "author": "jukanntenn",
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.17.0",
    "commander": "^13.0.0",
    "jsonrepair": "^3.12.0",
    "ky": "^1.7.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "rotating-file-stream": "^3.2.9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/pino": "^7.0.4",
    "esbuild": "^0.25.0",
    "eslint": "^10.7.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.63.0",
    "vitest": "^3.2.1"
  }
