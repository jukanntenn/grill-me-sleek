{
  "name": "@grilling-sleek/cli",
  "version": "0.2.0-rc.1",
  "description": "CLI tool for grilling-sleek - Stress-test your plan before vibe coding",
  "bin": {
    "grilling-sleek": "./dist/grilling-sleek.js"
  },
  "files": [
    "dist/grilling-sleek.js"
  ],
  "scripts": {
    "build": "node esbuild.config.mjs",
    "build:prod": "NODE_ENV=production node esbuild.config.mjs",
    "dev": "tsx src/grilling-sleek.ts",
    "lint": "eslint src/",
    "prepublishOnly": "pnpm run build:prod",
    "test": "vitest run"
  },
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
